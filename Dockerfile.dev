# Development stage - live reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies (npm ci if lock file exists, else npm install)
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Copy source (will be overwritten by volume mount)
COPY . .

# Eleventy dev server runs on 8080
EXPOSE 8080

CMD ["npm", "start"]
